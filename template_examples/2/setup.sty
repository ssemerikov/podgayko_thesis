\usepackage{chngcntr}
\counterwithin{table}{section}
\counterwithin{figure}{section}
% [5] Figure caption: "Рисунок 1.1 – Назва" (dash separator, centered, no indent)
% ДСТУ 3008:2015: пояснювальні дані і назву рисунка розміщують посередині рядка
\captionsetup[figure]{labelformat={default}, labelsep=endash,
    name={Рисунок}, justification=centering, font={it}}

% [6] Table caption: "Таблиця 1.1 – Назва" (dash separator, above table, left-aligned)
% ДСТУ 3008:2015: назву таблиці друкують з великої літери і розміщують над таблицею
\captionsetup[table]{labelformat={default}, labelsep=endash,
    name={Таблиця}, labelfont={it}, justification=raggedright, singlelinecheck=false}

% [9] Lists: Ukrainian letter hierarchy (а, б, в, г, д, е, ж, к, л, м, н, п, р, с, т, у, ф, х, ц, ш, щ)
% ДСТУ 3008:2015: малі літери укр. абетки (крім ґ, є, з, і, ї, й, о, ч, ь)
% Then Arabic numerals, then dashes. Indent each level by 1.25cm.
\setlist[enumerate,1]{label=\alph*), leftmargin=\parindent, itemindent=0pt}
\setlist[enumerate,2]{label=\arabic*), leftmargin=2\parindent, itemindent=0pt}
\setlist[itemize,1]{label=---, leftmargin=\parindent, itemindent=0pt}
\setlist[itemize,2]{label=---, leftmargin=2\parindent, itemindent=0pt}

% [10] Formula explanations: "де" without colon, no indent, new line
% (Applied manually in text — no package-level override needed)
% Pattern: formula, then "де X — пояснення;" on new line without indent

% [11] Cross-references: "рис. 1.1" in parentheses, "рисунок 1.1" in text
% (Applied manually — caption name is "Рисунок" per DSTU, text refs use "рис." abbreviated)

%% TikZ diagram styles for thesis figures
\tikzset{
  % Main header box (bold title, thick border)
  dia/header/.style={rectangle, draw, thick, text centered,
    font=\bfseries, text width=#1, inner sep=6pt, minimum height=1cm},
  dia/header/.default=10cm,
  % Regular content box (with optional text width)
  dia/box/.style={rectangle, draw, text width=#1, inner sep=5pt,
    minimum height=0.8cm, text centered},
  dia/box/.default=4cm,
  % Rounded content box
  dia/rbox/.style={rectangle, draw, rounded corners=4pt, text width=#1,
    inner sep=5pt, minimum height=0.8cm, text centered},
  dia/rbox/.default=4cm,
  % Left-aligned content box (for bullet lists)
  dia/lbox/.style={rectangle, draw, text width=#1, inner sep=5pt,
    align=left},
  dia/lbox/.default=4cm,
  % Left-aligned rounded content box
  dia/lrbox/.style={rectangle, draw, rounded corners=4pt, text width=#1,
    inner sep=5pt, align=left},
  dia/lrbox/.default=4cm,
  % Arrow styles
  dia/arrow/.style={-{Stealth[length=3mm]}, thick},
  dia/darrow/.style={{Stealth[length=3mm]}-{Stealth[length=3mm]}, thick},
  dia/line/.style={thick},
  % Convergence point label (no border)
  dia/label/.style={text centered, font=\itshape},
}

