% ============================================================
% ДСТУ 3008:2015 — Styling
% ============================================================

% [1] Line spacing: 1.5 (Word-equivalent for 14pt = \linespread{1.25})
\linespread{1.25}

% [2] Page numbers: top-right corner, Arabic numerals
\pagestyle{fancy}
\fancyhf{}
\fancyhead[R]{\thepage}
\renewcommand{\headrulewidth}{0pt}
% Also restyle 'plain' pages (chapter starts) to match
\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyhead[R]{\thepage}%
  \renewcommand{\headrulewidth}{0pt}%
}
% [3] Title page: no page number (\begin{titlepage} handles this automatically)

% [8] Prevent orphaned headings (heading at page bottom without text)
\widowpenalty=10000
\clubpenalty=10000

%  Формати
\usepackage{etoolbox}
\patchcmd{\tableofcontents}{\contentsname}{\centering\contentsname}{}{}

% --- Section heading formats (titlesec) per ДСТУ 3008:2015 ---
% [7] Headings separated from text by one blank line (before and after)

% Numbered section: РОЗДІЛ N (new line) UPPERCASE TITLE, both centered, bold
\titleformat{\section}[display]
  {\centering\bfseries\Large}
  {РОЗДІЛ~\thesection}
  {0pt}
  {}
\titlespacing{\section}{0pt}{1.5em}{1.5em}

% Unnumbered section*: centered title only
\titleformat{name=\section,numberless}
  {\centering\bfseries\Large}
  {}
  {0pt}
  {}
\titlespacing{name=\section,numberless}{0pt}{1.5em}{1.5em}

% [4] Subsection: normal weight, from paragraph indent, no period at end
% ДСТУ 3008:2015: друкують з абзацного відступу звичайним шрифтом з великої літери
\titleformat{\subsection}
  {\normalfont\large\bfseries}
  {\thesubsection.}
  {0.5em}
  {}
\titlespacing{\subsection}{\parindent}{1.5em}{1.0em}

% Subsubsection: 1.1.1. Title, normal weight, from indent
\titleformat{\subsubsection}
  {\normalfont\normalsize\bfseries}
  {\thesubsubsection.}
  {0.5em}
  {}
\titlespacing{\subsubsection}{\parindent}{1.0em}{0.5em}

% [8] Extra: require at least 3 lines after heading before page break
\AtBeginDocument{%
  \let\origsubsection\subsection
  \let\origsubsubsection\subsubsection
}

\setlength\parindent{1.25cm}

