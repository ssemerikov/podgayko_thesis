\usepackage{etoolbox}

\patchcmd{\tableofcontents}{\contentsname}{\centering\contentsname}{}{}

\makeatletter
%------------------ прапорець "ми в додатках" ------------------
\newif\if@inappendix
\@inappendixfalse

% Крапка після номера розділу, формат "1." "2."
\patchcmd{\@sect}{\csname the#1\endcsname}{\csname the#1\endcsname.}{}{}
\def\@seccntformat#1{\csname the#1\endcsname.\quad}

% Центруємо тільки \section
\patchcmd{\@sect}{#6}{\ifstrequal{#1}{section}{\centering#6}{#6}}{}{}

% Заміна префіксів у заголовку розділів
\patchcmd{\@sect}{\@hangfrom{\hskip #3\relax\@svsec}}{%
  \@hangfrom{\hskip #3\relax
    \ifstrequal{#1}{section}{%
      \if@inappendix
        ДОДАТОК~\thesection%
      \else
        РОЗДІЛ~\thesection%
      \fi
    }{\@svsec}}%
  \ifstrequal{#1}{section}{\par\nopagebreak}{}%
}{}{}

%------------------ формат заголовків у змісті ------------------
% \l@section{<назва>} генерує запис у змісті
\renewcommand*\l@section[2]{%
  \if@inappendix
      \addtocontents{toc}{\protect\contentsline{section}{ДОДАТОК~\thesection.\ #1}{#2}{}}%
  \else
      \addtocontents{toc}{\protect\contentsline{section}{РОЗДІЛ~\thesection.\ #1}{#2}{}}%
  \fi
}

%------------------ перевизначення \appendix ------------------
\renewcommand\appendix{%
  \par
  \@inappendixtrue
  \setcounter{section}{0}%
  \setcounter{subsection}{0}%
  \renewcommand\thesection{\Alph{section}}% A, B, C...
}
\makeatother
